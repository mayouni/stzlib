# Softanza reflect: generated example-index cache (rebuilt on demand from tests)
*.stzcache

# Neural model files (large; downloaded on demand)
*.gguf

# stzApp/stzPlatform test-run artifacts
**/test/**/.stzapp/

# generated cluster worker entry (R8.3)
**/cluster/.stzworker_gen.ring
**/appserver/.stzbackend_*
# generated mTLS test worker entry (R8 mTLS slice 4)
**/mtls_certs/.mtls_worker_gen.ring

# stzBuilder test scratch (build artifacts; test cleans up, this guards a mid-run crash)
_build_scratch/
_deploy_scratch/
_wasmsub_tmp/
# StzDirDeleteAll / dir-listing probes (ephemeral)
**/_delprobe/
**/_delprobe2/
**/_treeprobe/
# generated emulator bundles (Deploy(:Emulated) output; regenerated on demand)
**/restolean_emulator/
