# Narrative
# --------
# Testing different movement directions
#
# Extracted from stzTileTest.ring, block #3.

load "../../stzBase.ring"


pr()

o1 = new stzTile([5, 5])
? @@(o1.SizeXT()) + NL
#--> [5, 5 ]

# Moving to center of Tile

o1.MoveTo(3, 3) + NL
o1.Show() + NL
#-->
#     1   2   3   4   5   
#   в•ӯв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җvв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв•®
