load "../../stzBase.ring"
load "../_narrated.ring"

# stzListOfChars: Boxify renders the cell strip; BoxDash uses dashed
# lines. (The archive's lone rounded corner on Boxify was a one-char
# garble; the box is rectangular, like its own BoxDash.)
# Archive block #952.

Scenario("A char list in cells, twice")
	o1 = new stzListOfChars( @Chars("..STZ..StZ..stz") )
	Then("solid cells",
		o1.Boxify(),
		"в”Ңв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”җ" + NL +
		"в”Ӯ . в”Ӯ . в”Ӯ S в”Ӯ T в”Ӯ Z в”Ӯ . в”Ӯ . в”Ӯ S в”Ӯ t в”Ӯ Z в”Ӯ . в”Ӯ . в”Ӯ s в”Ӯ t в”Ӯ z в”Ӯ" + NL +
		"в””в”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҳ")
	Then("dashed cells",
		o1.BoxDash(),
		"в”Ңв•Ңв•Ңв•Ңв”¬в•Ңв•Ңв•Ңв”¬в•Ңв•Ңв•Ңв”¬в•Ңв•Ңв•Ңв”¬в•Ңв•Ңв•Ңв”¬в•Ңв•Ңв•Ңв”¬в•Ңв•Ңв•Ңв”¬в•Ңв•Ңв•Ңв”¬в•Ңв•Ңв•Ңв”¬в•Ңв•Ңв•Ңв”¬в•Ңв•Ңв•Ңв”¬в•Ңв•Ңв•Ңв”¬в•Ңв•Ңв•Ңв”¬в•Ңв•Ңв•Ңв”¬в•Ңв•Ңв•Ңв”җ" + NL +
		"в”Ҡ . в”Ҡ . в”Ҡ S в”Ҡ T в”Ҡ Z в”Ҡ . в”Ҡ . в”Ҡ S в”Ҡ t в”Ҡ Z в”Ҡ . в”Ҡ . в”Ҡ s в”Ҡ t в”Ҡ z в”Ҡ" + NL +
		"в””в•Ңв•Ңв•Ңв”ҙв•Ңв•Ңв•Ңв”ҙв•Ңв•Ңв•Ңв”ҙв•Ңв•Ңв•Ңв”ҙв•Ңв•Ңв•Ңв”ҙв•Ңв•Ңв•Ңв”ҙв•Ңв•Ңв•Ңв”ҙв•Ңв•Ңв•Ңв”ҙв•Ңв•Ңв•Ңв”ҙв•Ңв•Ңв•Ңв”ҙв•Ңв•Ңв•Ңв”ҙв•Ңв•Ңв•Ңв”ҙв•Ңв•Ңв•Ңв”ҙв•Ңв•Ңв•Ңв”ҙв•Ңв•Ңв•Ңв”ҳ")
EndScenario()

Summary()
