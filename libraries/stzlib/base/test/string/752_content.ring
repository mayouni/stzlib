# Extracted from stzStringTest.ring, block #752.
#ERR Error (R20) : Calling function with extra number of parameters

load "../../stzBase.ring"

pr()

StzStringQ("RING IS NICE") {

	? Content()

	? Boxed()
	? BoxedRound()

	? EachCharBoxed()
	? EachCharBoxedRounded()

	? VizFindBoxed("I")

	? BoxedDashed()
	? BoxedDashedRounded()

	? CharsBoxedXT([
		:Line = :Solid,
		:Corners = [
			:Round, :Rectangular,
			:Round, :Rectangular
		]
	])

}

