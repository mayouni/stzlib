load "../../stzBase.ring"
load "../_narrated.ring"

# VizFindBoxedCSXT: the cell strip with a bullet under each match
# START. Archive block #955.

Scenario("Four bulleted matches")
	o1 = new stzString("..STZ..StZ..stz...STZ")
	Then("bullets at 3, 8, 13 and 19",
		o1.VizFindBoxedCSXT("STZ", :CS = FALSE, [ :Numbered = TRUE ]),
		"в”Ңв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”җ" + NL +
		"в”Ӯ . в”Ӯ . в”Ӯ S в”Ӯ T в”Ӯ Z в”Ӯ . в”Ӯ . в”Ӯ S в”Ӯ t в”Ӯ Z в”Ӯ . в”Ӯ . в”Ӯ s в”Ӯ t в”Ӯ z в”Ӯ . в”Ӯ . в”Ӯ . в”Ӯ S в”Ӯ T в”Ӯ Z в”Ӯ" + NL +
		"в””в”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҙв”ҖвҖўв”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҙв”ҖвҖўв”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҙв”ҖвҖўв”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҙв”ҖвҖўв”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҳ")
EndScenario()

Summary()
