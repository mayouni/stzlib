#       AVERAGE в”‚     4.15 в”‚     4.10 в”‚     4.28 в”‚     4.25 в”‚    4.19  

		# Count of Products by Category and Region + NL
    
		SetRowLabels([:Category])
        SetColumnLabels([:Region])
        SetValues([:Product])
        SetAggregateFunction("COUNT") #todo // check error un COUNT
        Show()
		#-->
