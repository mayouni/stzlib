# Testing forward/backward movement
#
# Extracted from stzTileTest.ring, block #4.

load "../../../stzBase.ring"


pr()

o1 = new stzTile([4, 3])

# Default Direction
? o1.Direction() + NL

# Starting position [1, 1]

o1.Show() + NL
#-->
#     1   2   3   4   
#   в•ӯв”Җvв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв•®
# 1 > вҷҘ в”Ӯ   в”Ӯ   в”Ӯ   в”Ӯ
#   в”ңв”Җв”Җв”Җв”јв”Җв”Җв”Җв”јв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Ө
# 2 в”Ӯ   в”Ӯ   в”Ӯ   в”Ӯ   в”Ӯ
#   в”ңв”Җв”Җв”Җв”јв”Җв”Җв”Җв”јв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Ө
# 3 в”Ӯ   в”Ӯ   в”Ӯ   в”Ӯ   в”Ӯ
